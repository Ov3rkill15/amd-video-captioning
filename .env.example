FIREWORKS_API_KEY=your_fireworks_api_key_here
# kimi-k2p6 is the default: serverless (pay-per-token) and vision-capable.
# gemma-4-26b-a4b-it (Google DeepMind, bonus prize) is only available via Dedicated
# Deployment (hourly GPU rental) on our Fireworks account, not serverless —
# change the value below once a Gemma deployment is active.
FIREWORKS_VLM_MODEL=accounts/fireworks/models/kimi-k2p6
# Optional overrides (defaults shown):
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# INPUT_PATH=/input/tasks.json    # agent.py only, for local development
# OUTPUT_PATH=/output/results.json
