FIREWORKS_API_KEY=your_fireworks_api_key_here
# kimi-k2p6 dipakai default: serverless (pay-per-token) dan vision-capable.
# gemma-4-26b-a4b-it (Google DeepMind, bonus prize) hanya tersedia via Dedicated
