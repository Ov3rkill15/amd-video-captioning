FIREWORKS_API_KEY=your_fireworks_api_key_here
# For the public submission image, convert the line above to its base64 form
# (FIREWORKS_API_KEY_B64=...) by running: python scripts/encode_key.py
# This keeps the key away from regex-based secret scanners on public registries.
# The client accepts either variable (plain takes precedence).
# kimi-k2p6 is the default: serverless (pay-per-token) and vision-capable.
# gemma-4-26b-a4b-it (Google DeepMind, bonus prize) is only available via Dedicated
# Deployment (hourly GPU rental) on our Fireworks account, not serverless —
# change the value below once a Gemma deployment is active.
FIREWORKS_VLM_MODEL=accounts/fireworks/models/kimi-k2p6
# Optional overrides (defaults shown):
# FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
# INPUT_PATH=/input/tasks.json    # agent.py only, for local development
# OUTPUT_PATH=/output/results.json
# --- Gemma A/B eval only (scripts/eval_captions.py --variants baseline,gemma) ---
# Serves Gemma from any OpenAI-compatible host; OpenRouter is the default.
# The judge still runs on FIREWORKS_* so scores stay comparable.
# GEMMA_API_KEY=your_openrouter_api_key_here
# GEMMA_MODEL=google/gemma-4-26b-a4b-it
# GEMMA_BASE_URL=https://openrouter.ai/api/v1
